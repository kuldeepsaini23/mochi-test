/// In-app notification delivered to a specific user within an organization.
/// Org-scoped: every notification belongs to exactly one organization.
/// Category is a free-text string so new notification types can be added
/// without schema migrations (e.g., 'payment', 'lead', 'automation',
/// 'form', 'appointment', 'system', 'invoice', 'contract').
model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   // The recipient user (member of the organization)

  // Notification content
  title    String  // Short headline shown in the notification list
  body     String  // Longer description / detail text
  category String  // Logical grouping: 'payment', 'lead', 'automation', 'form', 'appointment', 'system', etc.

  // Optional deep-link URL the user is taken to when clicking the notification
  actionUrl String?

  // Read state tracking
  isRead Boolean   @default(false)
  readAt DateTime? // Timestamp when the user marked this notification as read

  // Timestamps
  createdAt DateTime @default(now())

  // Relations — org-scoped, cascade-delete when org or user is removed
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite index for the primary query: "all unread notifications for a
  // user in an org, newest first". Covering organizationId + userId + isRead
  // + createdAt lets Postgres satisfy the WHERE + ORDER BY from one index scan.
  @@index([organizationId, userId, isRead, createdAt])

  // Secondary indexes for common access patterns
  @@index([organizationId]) // Org-wide notification queries / admin views
  @@index([userId])         // Cross-org notification lookup for a user

  @@map("notification")
}


  updatedAt DateTime @updatedAt

  // Relations
  chatWidget ChatWidget @relation(fields: [chatWidgetId], references: [id], onDelete: Cascade)

  @@index([chatWidgetId])
  @@map("chatWidgetUpdate")
}

// ============================================================================
// ORGANIZATION WALLET (USAGE-BASED BILLING)
// ============================================================================
// SOURCE OF TRUTH: OrganizationWallet, WalletTransaction, WalletTransactionType,
//                  WalletTransactionStatus, WalletChargeCategory
//
// The wallet system enables usage-based billing for organizations.
// - Each organization has one wallet created automatically with $1 free funds
// - Charges are deducted from the wallet (AI usage, SMS, email, storage, etc.)
// - Auto top-up triggers when balance drops below $0 (charges $10 minimum)
// - Manual top-ups can be done at any time (minimum $10)

/// Transaction type - whether this is adding or removing funds
/// SOURCE OF TRUTH: WalletTransactionType
enum WalletTransactionType {
  TOP_UP // Adding funds (manual or auto)
  CHARGE // Deducting funds (usage)
  REFUND // Refunding a charge
}

/// Transaction status - current state of the transaction
/// SOURCE OF TRUTH: WalletTransactionStatus
enum WalletTransactionStatus {
  PENDING // Transaction initiated
  COMPLETED // Transaction completed successfully
  FAILED // Transaction failed
}

/// Charge category - what the charge was for
/// SOURCE OF TRUTH: WalletChargeCategory
enum WalletChargeCategory {
  // Top-up categories
  AUTO_TOP_UP // Automatic top-up when balance < $0
  MANUAL_TOP_UP // Manual top-up by user
  FREE_CREDIT // Free credit (e.g., initial $1)
  REFUND // Refund of a previous charge

  // Usage categories
  AI_USAGE // AI model usage (GPT, Claude, etc.)
  SMS // SMS messages sent
  EMAIL // Emails sent
  STORAGE // Storage overage
  API_CALLS // API calls beyond free tier
  OTHER // Miscellaneous charges
}

/// Organization wallet - stores balance and auto-top-up settings
/// One wallet per organization, created automatically with $1 free funds
/// SOURCE OF TRUTH: OrganizationWallet
model OrganizationWallet {
  id             String @id @default(cuid())
  organizationId String @unique // One wallet per organization

  // Balance in MILLICENTS (e.g., 1000 = $1.00, 10000 = $10.00)
  // Using millicents to handle sub-cent PAYG pricing ($0.015, $0.008) without floating point issues
  balance  Int    @default(1000) // Start with $1.00 (1000 millicents) free credit
  currency String @default("USD")

  // Auto top-up settings
  autoTopUpEnabled   Boolean @default(true) // Enable/disable auto top-up
  autoTopUpThreshold Int     @default(0) // Balance threshold to trigger top-up (millicents)
  autoTopUpAmount    Int     @default(1000) // Amount to top-up (millicents) - minimum $1

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([organizationId])
  @@map("organizationWallet")
}

/// Wallet transaction - individual top-ups, charges, and refunds
/// Provides full audit trail of all wallet activity
/// SOURCE OF TRUTH: WalletTransaction
model WalletTransaction {
  id       String @id @default(cuid())
  walletId String

  // Transaction details
  type     WalletTransactionType
  status   WalletTransactionStatus @default(PENDING)
  category WalletChargeCategory

  // Amount in MILLICENTS (positive for top-ups, negative for charges; 1000 = $1.00)
  amount   Int
  currency String @default("USD")

  // Balance after this transaction (for historical tracking)
  balanceAfter Int

  // Description for display
  description String

  // Optional metadata (JSON) for additional context
  // e.g., { "model": "gpt-4", "tokens": 1500 } for AI usage
  metadata String? @db.Text

  // Stripe payment intent ID (for top-ups that involve payment)
  stripePaymentIntentId String?

  // Reference to original transaction (for refunds)
  refundedTransactionId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wallet              OrganizationWallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  refundedTransaction WalletTransaction?  @relation("Refund", fields: [refundedTransactionId], references: [id], onDelete: SetNull)
  refunds             WalletTransaction[] @relation("Refund")

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("walletTransaction")
}

// ============================================================================
// CLIENT PORTAL (PLATFORM ADMIN)
// ============================================================================
// SOURCE OF TRUTH: PortalAdmin, PortalRole, PortalSession, PortalAuditLog, PortalSettings
// These models power the Client Portal - the master admin dashboard for MOCHI platform owners
// and their team members to manage all organizations on the platform.

/// Portal admin role definitions
/// Defines the available roles and their permissions for portal access
/// SOURCE OF TRUTH: PortalRole
enum PortalRoleType {
  OWNER // Full platform access - can manage everything including other admins
  ADMIN // Can manage organizations, users, view analytics - cannot manage other admins
  SUPPORT // Can view organizations, users, impersonate for support - cannot modify settings
  VIEWER // Read-only access to analytics and reports
}

/// Portal admin users - team members who can access the Client Portal
/// These are platform-level administrators separate from organization members
/// SOURCE OF TRUTH: PortalAdmin
model PortalAdmin {
  id     String         @id @default(cuid())
  email  String         @unique // Primary identifier - must match a User email
  userId String?        @unique // Optional link to User table for existing platform users
  role   PortalRoleType @default(ADMIN) // Role determines permissions

  // Profile info (can be different from User profile)
  displayName String?
  avatarUrl   String?

  // Security & Access Control
  isActive    Boolean   @default(true) // Can be deactivated without deletion
  lastLoginAt DateTime? // Track last portal access
  lastLoginIp String? // Track last login IP for security
  invitedBy   String? // PortalAdmin ID who invited this admin
  invitedAt   DateTime? // When they were invited

  // Two-factor for extra portal security (separate from user 2FA)
  portalTwoFactorEnabled Boolean @default(false)
  portalTwoFactorSecret  String? // TOTP secret for portal-specific 2FA

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessions     PortalSession[] // Active portal sessions
  auditLogs    PortalAuditLog[] @relation("PerformedBy") // Actions this admin performed
  targetedLogs PortalAuditLog[] @relation("TargetAdmin") // Audit logs where this admin was the target

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("portalAdmin")
}

/// Portal sessions - separate from regular user sessions for extra security
/// Portal sessions have stricter timeout and require re-authentication
/// SOURCE OF TRUTH: PortalSession
model PortalSession {
  id            String @id @default(cuid())
  portalAdminId String

  // Session token (hashed for security)
  tokenHash String @unique // SHA-256 hash of the session token

  // Security metadata
  ipAddress  String // IP address when session was created
  userAgent  String // Browser/client info
  deviceInfo String? // Parsed device info (optional)

  // Session lifecycle
  expiresAt      DateTime // Portal sessions have shorter expiry (e.g., 4 hours)
  lastActivityAt DateTime @default(now()) // Updated on each portal action

  // Flags
  isRevoked     Boolean   @default(false) // Manually revoked by admin or security system
  revokedAt     DateTime? // When session was revoked
  revokedReason String? // Why session was revoked

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  portalAdmin PortalAdmin @relation(fields: [portalAdminId], references: [id], onDelete: Cascade)

  @@index([portalAdminId])
  @@index([expiresAt])
  @@index([isRevoked])
  @@map("portalSession")
}

/// Portal audit log - comprehensive logging of all portal actions for security
/// Every action in the portal should be logged here for compliance and debugging
/// SOURCE OF TRUTH: PortalAuditLog
model PortalAuditLog {
  id            String @id @default(cuid())
  portalAdminId String // Who performed the action

  // Action details
  action     String // e.g., "organization.view", "user.impersonate", "settings.update"
  resource   String // e.g., "organization", "user", "subscription", "settings"
  resourceId String? // ID of the affected resource (if applicable)

  // Request context
  ipAddress     String // IP address of the request
  userAgent     String // Browser/client info
  requestPath   String // API endpoint or page path
  requestMethod String // HTTP method (GET, POST, etc.)

  // Change tracking
  previousValue String? @db.Text // JSON of previous state (for updates)
  newValue      String? @db.Text // JSON of new state (for updates)
  metadata      String? @db.Text // Additional context as JSON

  // Outcome
  success      Boolean @default(true) // Whether action succeeded
  errorMessage String? // Error message if action failed

  // Target admin (for admin management actions)
  targetAdminId String? // If action affects another portal admin

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  portalAdmin PortalAdmin  @relation("PerformedBy", fields: [portalAdminId], references: [id], onDelete: Cascade)
  targetAdmin PortalAdmin? @relation("TargetAdmin", fields: [targetAdminId], references: [id], onDelete: SetNull)

  @@index([portalAdminId])
  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([createdAt])
  @@index([targetAdminId])
  @@map("portalAuditLog")
}

/// Portal settings - platform-wide configuration stored in database
/// Allows dynamic configuration without ENV changes
/// SOURCE OF TRUTH: PortalSettings
model PortalSettings {
  id    String @id @default(cuid())
  key   String @unique // Setting key (e.g., "portal.session.timeout")
  value String @db.Text // JSON value for flexibility

  // Metadata
  description String? // Human-readable description
  category    String // Grouping (e.g., "security", "notifications", "ui")
  isSecret    Boolean @default(false) // If true, value should be masked in UI

  // Audit trail
  lastUpdatedBy String? // PortalAdmin ID who last updated
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([category])
  @@map("portalSettings")
}

/// Portal invitations - for inviting new team members to the portal
/// Separate from organization invitations
/// SOURCE OF TRUTH: PortalInvitation
model PortalInvitation {
  id    String         @id @default(cuid())
  email String // Email to invite
  role  PortalRoleType @default(ADMIN) // Role to assign

  // Invitation token (hashed)
  tokenHash String @unique // SHA-256 hash of invitation token

  // Lifecycle
  expiresAt  DateTime // When invitation expires (e.g., 7 days)
  acceptedAt DateTime? // When invitation was accepted

  // Tracking
  invitedBy String // PortalAdmin ID who sent the invitation

  // Timestamps
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("portalInvitation")
}

// ============================================================================
// AUTOMATION BUILDER
// ============================================================================
// SOURCE OF TRUTH: Automation, AutomationRun, AutomationTriggerType, AutomationStatus,
//                  AutomationRunStatus, AutomationSchema
//
// The automation system enables users to create automated workflows triggered by events.
// - Each automation has ONE trigger (event that starts the workflow)
// - Triggers fire actions in sequence (or with conditions/delays)
// - Context is maintained throughout the run (lead, transaction, form data, etc.)
// - Variables can be interpolated using the existing {{variable}} system
//
// ARCHITECTURE:
// - Automation stores the workflow definition (nodes/edges from React Flow)
// - AutomationRun tracks each execution with status and step logs
// - Trigger.dev handles the actual execution with context persistence
//
// HARD DELETE: Automations are permanently deleted, runs are kept for audit

/// Automation trigger types - events that can start an automation
/// SOURCE OF TRUTH: AutomationTriggerType
enum AutomationTriggerType {
  // Lead-based triggers
  FORM_SUBMITTED // When a form is submitted (creates or updates lead)
  LEAD_CREATED // When a new lead is created
  LEAD_UPDATED // When an existing lead is updated

  // Tag triggers
  TAG_ADDED // When a tag is added to a lead
  TAG_REMOVED // When a tag is removed from a lead

  // Pipeline triggers
  PIPELINE_TICKET_MOVED // When a pipeline ticket is updated

  // Payment triggers
  PAYMENT_COMPLETED // When a Stripe payment is successful
  TRIAL_STARTED // When a trial subscription begins ($0 charged)
  SUBSCRIPTION_RENEWED // When a recurring subscription payment succeeds (2nd+ invoice)
  SUBSCRIPTION_CANCELLED // When a subscription ends (cancel, churn, payment failure)

  // Appointment triggers
  APPOINTMENT_SCHEDULED // When an appointment is booked
  APPOINTMENT_STARTED // When an appointment start time is reached

  // Email engagement triggers
  EMAIL_OPENED // When a tracked email is opened
  EMAIL_CLICKED // When a link in email is clicked
}

/// Automation status - the lifecycle state of an automation
/// SOURCE OF TRUTH: AutomationStatus
enum AutomationStatus {
  DRAFT // Being edited, won't fire on triggers
  ACTIVE // Live and will fire on matching triggers
  PAUSED // Temporarily disabled, can be reactivated
  ARCHIVED // Soft-archived, hidden from main list but kept for reference
}

/// Automation run status - the execution state of a single run
/// SOURCE OF TRUTH: AutomationRunStatus
enum AutomationRunStatus {
  PENDING // Queued, waiting to start
  RUNNING // Currently executing
  WAITING // Paused, waiting for delay or event
  COMPLETED // Successfully finished all steps
  FAILED // Encountered an error and stopped
  CANCELLED // Manually cancelled by user or system
}

/// Automation - A workflow definition with trigger and actions
/// SOURCE OF TRUTH: Automation, AutomationWorkflow, AutomationDefinition
model Automation {
  id             String @id @default(cuid())
  organizationId String

  // Basic info
  name        String
  description String?

  // URL-safe identifier for direct links (generated from name)
  // Unique per organization, similar to Form.slug
  slug String?

  // Status controls whether automation fires on triggers
  status AutomationStatus @default(DRAFT)

  // Trigger configuration - ONE trigger per automation
  // This defines what event starts the automation
  triggerType   AutomationTriggerType
  triggerConfig Json? // Trigger-specific config (e.g., which form, which tag, which pipeline)

  // Workflow schema - stores React Flow nodes and edges
  // Structure: { nodes: Node[], edges: Edge[] }
  // Each node has: id, type, position, data (with action config)
  // Each edge has: id, source, target, sourceHandle, targetHandle
  schema Json @default("{\"nodes\":[],\"edges\":[]}")

  // Statistics (denormalized for quick access)
  totalRuns      Int       @default(0)
  successfulRuns Int       @default(0)
  failedRuns     Int       @default(0)
  lastRunAt      DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Folder organization (optional - null means root level)
  folderId String?
  folder   AutomationFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         AutomationRun[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, triggerType])
  @@index([triggerType, status])
  @@index([organizationId, folderId])
  @@map("automation")
}

/// AutomationFolder - Folder organization for automations
/// Supports nested folder hierarchy (self-referencing)
/// SOURCE OF TRUTH: AutomationFolder, AutomationFolderHierarchy
model AutomationFolder {
  id             String @id @default(cuid())
  organizationId String

  // Folder metadata
  name  String // Display name (e.g., "Marketing Workflows", "Onboarding")
  color String? // Optional hex color for visual distinction (e.g., "#3B82F6")

  // Folder hierarchy (self-referencing for nesting)
  parentId String?
  parent   AutomationFolder?  @relation("AutomationFolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children AutomationFolder[] @relation("AutomationFolderHierarchy")

  // Automations in this folder
  automations Automation[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, parentId])
  @@map("automation_folder")
}

/// AutomationRun - A single execution of an automation
/// Tracks the progress and results of each run
/// SOURCE OF TRUTH: AutomationRun, AutomationExecution, WorkflowRun
model AutomationRun {
  id             String  @id @default(cuid())
  automationId   String? // Optional: null when automation is deleted (audit trail preserved)
  organizationId String // Denormalized for efficient queries

  // Run status
  status AutomationRunStatus @default(PENDING)

  // Trigger context - the data that started this run
  // Contains leadId, and trigger-specific data (formSubmission, transaction, etc.)
  // This is the SOURCE OF TRUTH for variable interpolation during execution
  triggerData Json

  // Execution log - array of step results
  // Structure: [{ nodeId, nodeType, status, startedAt, completedAt, result?, error? }]
  // Updated as each node executes
  steps Json @default("[]")

  // Current position in workflow (for resuming after waits)
  currentNodeId String?

  // Trigger.dev integration
  triggerDevRunId String? @unique // Reference to the Trigger.dev run for monitoring

  // Wait token for wait-for-event actions
  // When automation is waiting for an event, this token is used to resume
  waitTokenId String?

  // Error information (if failed)
  error String? @db.Text

  // Timing
  startedAt   DateTime?
  completedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  automation Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  // Note: Using SetNull so runs are preserved when automation is deleted (audit trail)

  @@index([automationId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
  @@index([triggerDevRunId])
  @@index([createdAt])
  @@map("automationRun")
/// Activity Log - Tracks user create/update/delete actions across the platform
/// Used for platform analytics, audit trails, and churn detection
/// SOURCE OF TRUTH: ActivityLog, PlatformActivityTracking
}
model ActivityLog {
  id             String   @id @default(cuid())
  userId         String   // User who performed the action
  organizationId String   // Organization context
  action         String   // "create" | "update" | "delete"
  entity         String   // Entity type (e.g., "website", "form", "lead", "product")
  entityId       String   // ID of the affected entity
  createdAt      DateTime @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([action])
  @@index([entity])
  @@map("activity_log")
}

// ============================================================================
// INVOICES
// ============================================================================

/// Invoice status lifecycle: DRAFT → SENT → PAID (or OVERDUE / CANCELED)
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELED
}

/// Invoice — Billable document sent to a lead for payment.
///
/// Follows the Contract model pattern: CRUD with rich-text notes (Lexical JSON),
/// a public accessToken for the view/pay link, and Stripe integration for payments.
///
/// SOURCE OF TRUTH KEYWORDS: Invoice, InvoiceModel, InvoiceBilling
model Invoice {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?  // Recipient lead (optional — can be assigned later)

  // Invoice identity
  invoiceNumber String  // Auto-generated per org, e.g. "INV-0001"
  name          String  // Display name (e.g. "Website Redesign Invoice")

  // Status & lifecycle
  status InvoiceStatus @default(DRAFT)

  // Rich-text notes (Lexical SerializedEditorState JSON)
  // Supports dynamic variable pills (lead.firstName, org.name, etc.)
  notes Json?

  // Payment details
  dueDate     DateTime?
  currency    String    @default("usd")
  totalAmount Int       @default(0) // Sum of all items, in cents

  // Public access link — generated on send, used for /invoice/[accessToken]
  accessToken String? @unique

  // Stripe references for tracking payment
  stripePaymentIntentId String? @unique
  stripeSubscriptionId  String? @unique

  // Receipt link — when invoice is generated from a payment receipt,
  // this links to the TransactionPayment that originated the invoice.
  // Enables the receipt page to show "Download Invoice" for already-generated invoices.
  transactionPaymentId String? @unique

  // Timestamps
  sentAt    DateTime? // When the invoice was sent to the lead
  paidAt    DateTime? // When the invoice was paid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  payment      TransactionPayment? @relation(fields: [transactionPaymentId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([leadId])
  @@index([accessToken])
  @@index([transactionPaymentId])
  @@map("invoice")
}

/// InvoiceItem — A line item on an invoice.
///
/// Can reference an existing Product/Price (productId + priceId) or be
/// an ad-hoc one-time item (isAdHoc: true) with no product reference.
///
/// SOURCE OF TRUTH KEYWORDS: InvoiceItem, InvoiceLineItem
model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String

  // Product reference (null for ad-hoc items)
  productId String?
  priceId   String?

  // Line item details (snapshots — don't change if product is updated later)
  name        String  // Product name or custom item name
  description String? // Optional description for the line item

  // Pricing
  quantity    Int @default(1)
  unitAmount  Int // Price per unit in cents
  totalAmount Int // quantity × unitAmount, in cents

  // Billing type (mostly ONE_TIME for invoices, but supports recurring)
  billingType   BillingType     @default(ONE_TIME)
  interval      BillingInterval? // For recurring items
  intervalCount Int?             // How many intervals between payments
  trialDays     Int?             // Free trial duration in days — mirrors ProductPrice.trialDays

  // Whether this is an ad-hoc item (not linked to a product)
  isAdHoc Boolean @default(false)

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_item")
}

// ============================================================================
// PAGE VIEW MODEL - Website Analytics Tracking
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: PageView, WebsiteAnalytics, PageTracking, VisitorTracking
//
// WHY: Tracks page visits on live published websites. Used for:
// 1. Website metrics dashboard (total visits, unique visitors, per-page stats)
// 2. Lead activity timeline (PAGE_VISITED activity type)
// 3. UTM source attribution for leads
//
// HOW: A lightweight client component fires a non-blocking tRPC mutation when
// a visitor loads a published page. Server-side debounce (1 hour per visitorId + pageId)
// prevents spam from page refreshes.
//
// visitorId: Anonymous browser fingerprint stored in localStorage. Not a lead ID.
// When a visitor has a lead session, leadId is also populated for attribution.
//
// ONLY tracks live published pages — not preview/test/builder mode.
// ============================================================================

model PageView {
  id             String  @id @default(cuid())
  organizationId String
  websiteId      String
  pageId         String
  leadId         String? // Nullable — populated if visitor has an active lead session

  // Visitor identification (anonymous, localStorage-based)
  visitorId String // Browser-generated UUID stored in localStorage

  // Page context
  pathname String // URL path visited (e.g., "/home", "/about")

  // UTM tracking parameters
  utmSource   String? // utm_source from URL params
  utmMedium   String? // utm_medium from URL params
  utmCampaign String? // utm_campaign from URL params

  // Referrer tracking
  referrer String? // document.referrer value

  // Timestamp
  visitedAt DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  page         Page         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Indexes for efficient querying
  @@index([organizationId])
  @@index([websiteId])
  @@index([pageId])
  @@index([leadId])
  @@index([visitorId, pageId, visitedAt]) // Debounce check: same visitor + page within time window
  @@index([websiteId, visitedAt])         // Metrics queries: page views by date range
  @@index([organizationId, visitedAt])    // Org-wide analytics queries
  @@map("page_view")
}

// ============================================================================
// NOTIFICATION — In-app notifications for org members
// ============================================================================

/// In-app notification delivered to a specific user within an organization.
/// Org-scoped: every notification belongs to exactly one organization.
/// Category is a free-text string so new notification types can be added
/// without schema migrations (e.g., 'payment', 'lead', 'automation',
/// 'form', 'appointment', 'system', 'invoice', 'contract').
model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   // The recipient user (member of the organization)

  // Notification content
  title    String  // Short headline shown in the notification list
  body     String  // Longer description / detail text
  category String  // Logical grouping: 'payment', 'lead', 'automation', 'form', 'appointment', 'system', etc.

  // Optional deep-link URL the user is taken to when clicking the notification
  actionUrl String?

  // Read state tracking
  isRead Boolean   @default(false)
  readAt DateTime? // Timestamp when the user marked this notification as read

  // Timestamps
  createdAt DateTime @default(now())

  // Relations — org-scoped, cascade-delete when org or user is removed
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite index for the primary query: "all unread notifications for a
  // user in an org, newest first". Covering organizationId + userId + isRead
  // + createdAt lets Postgres satisfy the WHERE + ORDER BY from one index scan.
  @@index([organizationId, userId, isRead, createdAt])

  // Secondary indexes for common access patterns
  @@index([organizationId]) // Org-wide notification queries / admin views
  @@index([userId])         // Cross-org notification lookup for a user

  @@map("notification")
}

// ============================================================================
// PUSH SUBSCRIPTION — Web Push subscriptions for PWA push notifications
// ============================================================================

/// Web Push subscription for PWA push notifications.
/// Stores the browser's PushSubscription data so the server can send
/// native push notifications to the user's device even when the app is
/// closed or backgrounded.
///
/// Each record = one device/browser subscription for one user in one org.
/// A user can have multiple subscriptions (phone + laptop + tablet).
model PushSubscription {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   // The user who subscribed on this device

  // PushSubscription fields from the Web Push API
  endpoint String  // The push service URL (unique per browser instance)
  p256dh   String  // Client public key for payload encryption
  auth     String  // Shared auth secret for payload encryption

  createdAt DateTime @default(now())

  // Relations — cascade-delete when org or user is removed
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One push subscription per device/browser — endpoint is globally unique.
  // When a different user logs in on the same device, the record is updated
  // to point to the new user (upsert by endpoint).
  @@unique([endpoint])

  // Index for "send push to all of this user's devices in this org"
  @@index([organizationId, userId])

  @@map("push_subscription")
}

// ============================================================================
// SavedColor — Organization Brand/Reusable Colors
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: SavedColor, SavedColors, OrganizationColors, BrandColors
//
// Allows organizations to save and reuse brand colors across the website builder.
// Each color has a name (e.g., "Brand Blue") and a value (hex, rgba, or 'transparent').
// Colors are org-scoped and uniquely named within an org.
// ============================================================================

model SavedColor {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // Human-readable label ("Brand Blue", "Accent Red", etc.)
  color          String   // Color value: hex (#ff0000), rgba(r,g,b,a), or 'transparent'
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Cascade-delete when the organization is removed
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // No two colors in the same org can share a name
  @@unique([organizationId, name])

  // Fast lookup by org
  @@index([organizationId])

  @@map("saved_color")
}

// ============================================================================
// TEMPLATE CATEGORY — What feature type a template or item represents
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: TemplateCategory, TemplateCategoryEnum, TemplateFeatureType
//
// Each value maps to one of the app's core features. BLUEPRINT represents a
// multi-feature bundle (e.g., a full marketing funnel that combines website +
// automation + form).
// ============================================================================

enum TemplateCategory {
  WEBSITE       // Website with pages, components, and canvas data
  EMAIL         // Email template (React Email builder blocks)
  AUTOMATION    // Automation workflow (trigger + node schema)
  FORM          // Form with fields, logic gates, and settings
  CONTRACT      // Contract with Lexical editor content and variables
  PIPELINE      // Pipeline with lanes and ticket structure
  BOOKING       // Booking calendar with availability and settings
  CHAT_WIDGET   // Chat widget with config, FAQ items, and updates
  CMS_SCHEMA    // CMS table schema (columns only, no row data)
  PRODUCT       // Product with prices (Stripe IDs stripped)
  BLUEPRINT     // Multi-feature bundle combining several categories
}

// ============================================================================
// TEMPLATE STATUS — Lifecycle state of a template
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: TemplateStatus, TemplateStatusEnum, TemplateLifecycle
//
// Controls visibility and installability:
// - DRAFT: Work in progress, only visible to the author org
// - PUBLISHED: Available for installation by other orgs
// - ARCHIVED: Hidden from library but existing installs still work
// ============================================================================

enum TemplateStatus {
  DRAFT            // Work in progress — not visible in the library
  PUBLISHED        // Live and installable by any organization
  ARCHIVED         // Hidden from library — existing installs unaffected
  PENDING_APPROVAL // Paid template awaiting portal admin review
}

// ============================================================================
// TEMPLATE — A reusable, shareable package of one or more features
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: Template, TemplateModel, TemplatePackage
//
// A template is created by an organization and packages one or more TemplateItems
// (feature snapshots). Other organizations can install a template to recreate
// those features in their workspace.
//
// - originHash: SHA-256 fingerprint of the source features at snapshot time.
//   Used to detect duplicate templates and track lineage.
// - version: Monotonically increasing integer bumped on each publish.
// - installCount: Denormalized counter for library sorting/popularity.
// ============================================================================

model Template {
  id             String   @id @default(cuid())
  organizationId String

  // Template metadata
  name         String
  description  String? @db.Text
  category     TemplateCategory
  status       TemplateStatus @default(DRAFT)
  thumbnailUrl String?
  tags         String[] @default([])

  // Versioning — bumped each time the template is re-published
  version Int @default(1)

  // Price in cents — null means free. Currency resolved from platform Stripe account.
  price Int?

  // Rejection reason — set by portal admin when rejecting a PENDING_APPROVAL template.
  // Cleared when the template is re-published. Displayed to the creator so they can fix issues.
  rejectionReason String? @db.Text

  // Denormalized install counter for popularity sorting in the library
  installCount Int @default(0)

  // SHA-256 fingerprint of the source features at snapshot time
  // Used for duplicate detection and lineage tracking
  originHash String

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        TemplateItem[]
  installs     TemplateInstall[]

  @@index([organizationId])
  @@index([category, status])
  @@index([status])
  @@index([originHash])
  @@map("template")
}

// ============================================================================
// TEMPLATE ITEM — A single feature snapshot within a template
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: TemplateItem, TemplateItemModel, FeatureSnapshot
//
// Each item captures a JSON snapshot of one feature (website, form, automation,
// etc.) at the time the template was created. The snapshot is sanitized to
// remove PII, Stripe IDs, and org-specific references.
//
// - featureType: Which feature this item represents (may differ from the
//   parent template's category in BLUEPRINT templates).
// - sourceId: Original feature ID in the author's org (informational only).
// - snapshot: The sanitized JSON blob — structure varies per featureType.
// - dependsOn: Array of other TemplateItem IDs this item depends on during
//   installation (e.g., a form used inside an automation).
// - originHash: Per-item fingerprint for granular duplicate detection.
// - order: Installation order (topologically sorted).
// ============================================================================

model TemplateItem {
  id         String @id @default(cuid())
  templateId String

  // Which feature type this snapshot represents
  featureType TemplateCategory

  // Original feature ID in the author's org (informational, not a FK)
  sourceId   String
  sourceName String

  // Sanitized JSON snapshot — structure varies per featureType
  // See FeatureSnapshotMap in src/lib/templates/types.ts for per-type shapes
  snapshot Json

  // Other TemplateItem IDs this item depends on for installation
  // e.g., a form snapshot that an automation snapshot references
  dependsOn String[] @default([])

  // Per-item SHA-256 fingerprint for granular lineage tracking
  originHash String

  // Installation order (lower = installed first, topologically sorted)
  order Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([originHash])
  @@map("templateItem")
}

// ============================================================================
// TEMPLATE INSTALL — Record of a template being installed into an organization
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: TemplateInstall, TemplateInstallModel, InstallRecord
//
// Created each time an organization installs a template. Stores the ID mapping
// between the template's source IDs and the newly created feature IDs so that
// cross-references (e.g., form inside automation) are properly re-linked.
//
// - templateVersion: Snapshot of the template version at install time.
// - idMapping: JSON map of { oldId → newId } for all created features.
// - originHash: Hash of the template at install time for audit/lineage.
// ============================================================================

model TemplateInstall {
  id             String @id @default(cuid())
  templateId     String
  organizationId String
  installedById  String // User ID of the member who triggered the install

  // Version of the template at the time of installation
  templateVersion Int

  // ID mapping: { sourceFeatureId → newlyCreatedFeatureId }
  // Used to re-link cross-references between installed features
  idMapping Json

  // Hash of the template at install time for audit trail
  originHash String

  // Timestamp
  installedAt DateTime @default(now())

  // Relations
  template     Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([templateId])
  @@index([originHash])
  @@map("templateInstall")
}

// ============================================================================
// TEMPLATE ORIGIN MARKER — Tracks which features were created from templates
// ============================================================================
//
// SOURCE OF TRUTH KEYWORDS: TemplateOriginMarker, OriginMarker, FeatureLineage
//
// Stamped on every feature (form, page, automation, etc.) that was created
// by installing a template. Allows the system to:
// 1. Show "Installed from [Template Name]" badges in the UI.
// 2. Detect if a feature was already installed (prevent duplicates).
// 3. Trace lineage back to the original template + install record.
//
// The @@unique([featureType, featureId]) constraint ensures a feature can only
// have one origin marker — it either came from a template or it didn't.
// ============================================================================

model TemplateOriginMarker {
  id             String @id @default(cuid())
  organizationId String

  // Which feature type and which specific feature this marker is for
  featureType TemplateCategory
  featureId   String

  // Lineage references
  originHash String // Hash linking back to the template item's originHash
  templateId String // Template this feature was installed from (informational, not FK)
  installId  String // TemplateInstall record ID (informational, not FK)

  // Timestamp
  createdAt DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A feature can only have one origin marker
  @@unique([featureType, featureId])

  @@index([organizationId])
  @@index([originHash])
  @@index([featureId])
  @@map("templateOriginMarker")
}

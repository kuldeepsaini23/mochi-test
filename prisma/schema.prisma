// =============================================================================
// CHAT WIDGETS
// SOURCE OF TRUTH: ChatWidget, Organization, Conversation
// =============================================================================

model ChatWidget {
  id             String @id @default(cuid())
  organizationId String

  // Widget details
  name        String
  description String?

  // Configuration JSON - stores theme colors, behavior settings, welcome page text
  // Structure: { theme: ChatWidgetThemeColors, behavior: ChatWidgetBehavior, welcomePage: WelcomPageConfig }
  config Json?

  // Embed security - list of allowed domains that can embed this widget
